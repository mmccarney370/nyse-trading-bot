# =============================================
# NYSE Trading Bot — Environment Variables
# Copy this to .env and fill in your keys:
#   cp .env.example .env
# =============================================

# === REQUIRED: Alpaca Broker (paper trading works fine) ===
# Get keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
# Paper trading URL (default). Change to live URL only when you're ready.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === OPTIONAL: Nightly self-tuner (pick one or both) ===
# Two providers are supported. Set TUNER_PROVIDER in config.py to "claude" or "gemini".
# Default is "claude" when ANTHROPIC_API_KEY is present, falling back to Gemini otherwise.
#
# -- Claude Opus 4.7 (recommended, deeper reasoning + prompt caching) --
# Get key at: https://console.anthropic.com/settings/keys
# With prompt caching, nightly cost is ~$0.10 for Opus or ~$0.015 for Sonnet.
# NOTE: Your Claude.ai subscription (Pro/Max) is SEPARATE from the API and does
# NOT grant API access — you need a pay-as-you-go API key from the console.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -- Gemini 2.5 Flash (alternate / fallback) --
# Get key at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# === OPTIONAL: News Sentiment ===
# Get key at: https://newsapi.org/ (free tier = 100 requests/day)
# Without this, sentiment features default to 0.0 (neutral).
NEWS_API_KEY=your_newsapi_key_here

# === OPTIONAL: Ollama LLM Sentiment ===
# Install Ollama: https://ollama.ai/
# Pull models: ollama pull llama3.1:8b
# The bot auto-detects Ollama at localhost:11434.
# Uncomment to use a different host:
# OLLAMA_HOST=http://localhost:11434

# === OPTIONAL: Redis Caching ===
# Default: localhost:6379. Uncomment to customize.
# REDIS_HOST=localhost
# REDIS_PORT=6379
