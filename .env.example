# =============================================
# NYSE Trading Bot — Environment Variables
# Copy this to .env and fill in your keys:
#   cp .env.example .env
# =============================================

# === REQUIRED: Alpaca Broker (paper trading works fine) ===
# Get keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
# Paper trading URL (default). Change to live URL only when you're ready.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === OPTIONAL: Gemini Self-Tuning ===
# Get key at: https://ai.google.dev/
# Without this, the bot runs fine but won't auto-tune parameters nightly.
GEMINI_API_KEY=your_gemini_api_key_here

# === OPTIONAL: News Sentiment ===
# Get key at: https://newsapi.org/ (free tier = 100 requests/day)
# Without this, sentiment features default to 0.0 (neutral).
NEWS_API_KEY=your_newsapi_key_here

# === OPTIONAL: Ollama LLM Sentiment ===
# Install Ollama: https://ollama.ai/
# Pull models: ollama pull llama3.1:8b
# The bot auto-detects Ollama at localhost:11434.
# Uncomment to use a different host:
# OLLAMA_HOST=http://localhost:11434

# === OPTIONAL: Redis Caching ===
# Default: localhost:6379. Uncomment to customize.
# REDIS_HOST=localhost
# REDIS_PORT=6379
